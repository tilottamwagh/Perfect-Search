{
    "env": {
        "browser": true,
        "commonjs": true,
        "es2022": true,
        "node": true,
        "jest": true
    },
    "extends": [
        "eslint:recommended",
        "plugin:react/recommended"
    ],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "plugins": [
        "react"
    ],
    "settings": {
        "react": {
            "version": "detect"
        }
    },
    "rules": {
        "react/prop-types": "off",
        "no-console": "off"
    },
    "ignorePatterns": [
        ".webpack",
        "out",
        "node_modules"
    ]
}