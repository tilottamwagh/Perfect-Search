APP_NAME=Application display name
ENCRYPTION_KEY=32-plus character encryption key for local token storage

SLACK_WORKSPACE_URL=Slack workspace or app base URL
CONFLUENCE_BASE_URL=Confluence base URL such as https://your-org.atlassian.net
SERVICENOW_BASE_URL=ServiceNow instance base URL such as https://your-instance.service-now.com

WEBSITE_URL=Optional internal website URL to crawl and index
WEBSITE_NAME=Display name for website search results

MAX_RESULTS_PER_SOURCE=Maximum number of results returned per source
SEARCH_TIMEOUT_MS=Timeout in milliseconds for external source queries
CACHE_TTL_MINUTES=Minutes before cached search results or website index expire
SESSION_REFRESH_HOURS=Hours before local auth sessions are considered stale
